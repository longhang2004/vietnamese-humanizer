{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/longhang2004/vietnamese-humanizer/blob/main/examples/schema.json",
  "title": "Vietnamese Writing Skills example",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "skill",
    "domain",
    "register",
    "input",
    "context",
    "output",
    "output_mode",
    "patterns_triggered",
    "must_preserve",
    "must_not_add",
    "notes",
    "gold_output_mode",
    "gold_rewrite",
    "preservation_review"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^EX-[0-9]{3}$"},
    "skill": {
      "enum": [
        "humanizer-vi",
        "translationese-cleaner-vi",
        "grammar-checker-vi",
        "style-guide-vi"
      ]
    },
    "domain": {"type": "string", "minLength": 2},
    "register": {"type": "string", "minLength": 2},
    "input": {"type": "string", "minLength": 1},
    "context": {"type": "string"},
    "output": {"type": "string", "minLength": 1},
    "output_mode": {
      "enum": [
        "clean_rewrite",
        "review_comment",
        "needs_author_decision",
        "no_change"
      ]
    },
    "patterns_triggered": {
      "type": "array",
      "uniqueItems": true,
      "items": {"type": "string", "pattern": "^VI-(HUM|TRA|GRA|STY)-[A-Z][0-9]{2}$"}
    },
    "must_preserve": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"}
    },
    "must_not_add": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1, "pattern": ".*\\S.*"}
    },
    "notes": {"type": "string", "minLength": 1},
    "gold_output_mode": {"type": "boolean"},
    "gold_rewrite": {"type": "boolean"},
    "preservation_review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "meaning_preserved", "facts_preserved", "review_notes"],
      "properties": {
        "status": {
          "enum": [
            "unreviewed",
            "agent-reviewed",
            "maintainer-reviewed",
            "independently-reviewed"
          ]
        },
        "reviewer_id": {"type": "string", "minLength": 1},
        "review_method": {"type": "string", "minLength": 1},
        "reviewed_at": {"type": "string", "format": "date"},
        "meaning_preserved": {"type": "boolean"},
        "facts_preserved": {"type": "boolean"},
        "review_notes": {"type": "string", "minLength": 1}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "unreviewed"}}},
          "then": {
            "not": {
              "anyOf": [
                {"required": ["reviewer_id"]},
                {"required": ["review_method"]},
                {"required": ["reviewed_at"]}
              ]
            }
          },
          "else": {"required": ["reviewer_id", "review_method", "reviewed_at"]}
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {"properties": {"gold_rewrite": {"const": true}}},
      "then": {
        "properties": {
          "output_mode": {"enum": ["clean_rewrite", "no_change"]},
          "preservation_review": {
            "properties": {
              "status": {
                "enum": [
                  "agent-reviewed",
                  "maintainer-reviewed",
                  "independently-reviewed"
                ]
              },
              "meaning_preserved": {"const": true},
              "facts_preserved": {"const": true}
            }
          }
        }
      }
    }
  ]
}
